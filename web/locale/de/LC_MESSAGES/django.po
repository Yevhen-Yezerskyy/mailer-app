#: templates/panels/aap_settings/mail_servers/_mail_limits.html:88
#: templates/panels/aap_settings/mail_servers/_smtp_server.html:127
#: templates/panels/aap_settings/sending.html:99
#: templates/public/password_reset_confirm.html:54
#: templates/public/register.html:84
msgid "Сохранить"
msgstr "Speichern"

#: templates/panels/aap_audience/create/step_form.html:100
msgid "Команда / вопрос для ИИ ассистента."
msgstr "Befehl / Frage für den KI-Assistenten."

#: templates/panels/aap_audience/create/step_form.html:107
msgid ""
"Дайте команду и / или задайте вопрос асситенту ИИ. Команда будет применена к "
"описанию, на вопрос предлагается независимый ответ"
msgstr "Geben Sie einen Befehl und/oder stellen Sie dem KI-Assistenten eine Frage. Der Befehl wird auf die Beschreibung angewendet, auf die Frage wird eine unabhängige Antwort gegeben."

#: templates/panels/aap_audience/create/step_form.html:109
msgid "Выполнить / задать вопрос"
msgstr "Ausführen / eine Frage stellen"

#: templates/panels/aap_audience/create/step_form.html:114
msgid "Изменения сохранены"
msgstr "Änderungen gespeichert"

#: templates/panels/aap_audience/create/step_form.html:122
msgid "Команда / вопрос:"
