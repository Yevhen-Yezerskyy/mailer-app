msgstr "Clear search"

#: templates/panels/aap_audience/create/step_branches.html:112
#: templates/panels/aap_audience/create/step_cities.html:67
#: templates/panels/aap_audience/create/step_cities.html:173
msgid "Игнорировать"
msgstr "Sign up"

#: templates/panels/aap_audience/create/step_branches.html:131
#: templates/panels/aap_audience/create/step_branches.html:148
#: templates/panels/aap_audience/create/step_branches.html:164
#: templates/panels/aap_audience/create/step_cities.html:210
