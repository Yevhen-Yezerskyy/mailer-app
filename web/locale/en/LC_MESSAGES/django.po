#: templates/panels/aap_settings/sending.html:99
#: templates/public/password_reset_confirm.html:55
#: templates/public/register.html:83
msgid "Сохранить"
msgstr "Save"

#: templates/panels/aap_audience/create/step_form.html:100
msgid "Команда / вопрос для ИИ ассистента."
msgstr "Command / question for the AI assistant."

#: templates/panels/aap_audience/create/step_form.html:107
msgid ""
"Дайте команду и / или задайте вопрос асситенту ИИ. Команда будет применена к "
"описанию, на вопрос предлагается независимый ответ"
msgstr ""
"Give a command and/or ask a question to the AI assistant. The command will "
"be applied to the description; for the question, an independent answer is "
"provided."

#: templates/panels/aap_audience/create/step_form.html:109
msgid "Выполнить / задать вопрос"
msgstr "Execute / ask a question"

#: templates/panels/aap_audience/create/step_form.html:114
msgid "Изменения сохранены"
msgstr "Changes saved"

#: templates/panels/aap_audience/create/step_form.html:122
msgid "Команда / вопрос:"
msgstr "Command / question:"

#: templates/panels/aap_audience/create/step_form.html:126
msgid "Ответ ассистента ИИ:"
msgstr "AI assistant response:"

#: templates/panels/aap_audience/create/step_form.html:130
msgid "Выполнено"
msgstr "Done"

#: templates/panels/aap_audience/create/step_form.html:134
msgid "Вопрос от ассистента ИИ:"
msgstr "Question from the AI assistant:"

#: templates/panels/aap_audience/create/step_form.html:146
msgid "Очистить / начать с начала"
msgstr "Clear / start over"

#: templates/panels/aap_audience/create/step_mailing_list.html:23
#: templates/panels/overview.html:659 templates/panels/overview.html:800
#: templates/panels/overview.html:916
msgid "Рейтингование завершено"
msgstr "Ranking completed"

#: templates/panels/aap_audience/create/step_mailing_list.html:26
#: templates/panels/aap_audience/create/step_mailing_list.html:39
#: templates/panels/aap_audience/create/step_mailing_list.html:51
msgid "Отрейтинговано контактов:"
msgstr "Contacts rated:"

#: templates/panels/aap_audience/create/step_mailing_list.html:35
#: templates/panels/overview.html:659 templates/panels/overview.html:800
#: templates/panels/overview.html:917
msgid "Рейтингование запущено"
msgstr "Rating has started"

#: templates/panels/aap_audience/create/step_mailing_list.html:48
#: templates/panels/overview.html:659 templates/panels/overview.html:800
#: templates/panels/overview.html:918
msgid "Рейтингование приостановлено"
msgstr "Ranking suspended"

#: templates/panels/aap_audience/create/step_mailing_list.html:133
msgid ""
"Рейтинг контакта рассчитывается индивидуально для каждого контакта в списке "
"рассылки."
msgstr ""
"The contact rating is calculated individually for each contact in the "
"mailing list."

#: templates/panels/aap_audience/create/step_mailing_list.html:134
msgid ""
"Он определяет соответствие данных контакта поставленной задаче в списке "
"(продукт / компания / география)."
msgstr ""
"It determines whether the contact data matches the task in the list "
"(product / company / geography)."

#: templates/panels/aap_audience/create/step_mailing_list.html:135
msgid "Рейтинг присваивается от 1 до 100, где 1 — наилучший."
msgstr "The rating is assigned from 1 to 100, where 1 is the best."

#: templates/panels/aap_audience/create/step_mailing_list.html:136
msgid "Для формирования списка рассылки используется рейтинг отсечения."
msgstr "An exclusion rating is used to generate the mailing list."

#: templates/panels/aap_audience/create/step_mailing_list.html:137
msgid ""
"Контакты с рейтингом хуже (больше) рейтинга отсечения в список рассылки не "
"включаются."
msgstr ""
"Contacts with a rating worse than (greater than) the cutoff rating are not "
"included in the mailing list."

#: templates/panels/aap_audience/create/step_mailing_list.html:138
msgid ""
"Контакты с успешным (меньше или равным рейтингу отсечения) рейтингом "
"включаются в список."
msgstr ""
