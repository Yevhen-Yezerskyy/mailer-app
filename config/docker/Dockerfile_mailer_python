# FILE: config/docker/Dockerfile_mailer_python
# DATE: 2026-02-21
# PURPOSE: Unified Python runtime image for Django web, engine workers, and tools.

FROM python:3.12-slim

RUN apt-get update \
 && apt-get install -y --no-install-recommends \
      gettext \
      dnsutils \
      git \
      ca-certificates \
      curl \
      wget \
      nano \
      vim-tiny \
      less \
      procps \
      iproute2 \
      iptables \
      openssh-client \
      sshpass \
      tzdata \
      postgresql-client \
      libnss3 \
      libnspr4 \
      libatk1.0-0 \
      libatk-bridge2.0-0 \
      libcups2 \
      libdrm2 \
      libdbus-1-3 \
      libxkbcommon0 \
      libxcomposite1 \
      libxdamage1 \
      libxfixes3 \
      libxrandr2 \
      libgbm1 \
      libasound2 \
      libatspi2.0-0 \
      libxshmfence1 \
      libglib2.0-0 \
      libgtk-3-0 \
      libpango-1.0-0 \
      libcairo2 \
      libx11-6 \
      libx11-xcb1 \
      libxcb1 \
      libxext6 \
      libxrender1 \
      libxss1 \
      libxtst6 \
      fonts-liberation \
 && rm -rf /var/lib/apt/lists/*

COPY config/docker/mailer.lock.txt /tmp/requirements/mailer.lock.txt

RUN python -m pip install --no-cache-dir -U pip \
 && pip install --no-cache-dir -r /tmp/requirements/mailer.lock.txt \
 && PLAYWRIGHT_BROWSERS_PATH=/ms-playwright python -m playwright install chromium \
 && rm -rf /tmp/requirements

WORKDIR /app
ENV PYTHONUNBUFFERED=1
ENV PLAYWRIGHT_BROWSERS_PATH=/ms-playwright
